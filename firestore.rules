rules_version = '2';

// Firestore security rules for Coupley.
//
// Data model:
//   /users/{uid}                                       — user profile + tokens
//   /pairingCodes/{code}                               — ephemeral invite codes
//   /couples/{coupleId}                                — userIds: [uidA, uidB]
//     /moods/{moodId}                                  — author: userId
//       /reactions/{reactionId}                        — author: userId
//     /syncScores/{date}                               — daily rollup
//     /messages/{msgId}                                — chat messages
//     /quizzes/{quizId}                                — chat quizzes
//     /coupleProfile/{docId}                           — aggregated insights
//     /anniversaries/{id}                              — anniversary events
//     /pings/{pingId}                                  — presence heartbeats
//     /notifications/{id}                              — in-app notifications
//   /ai_usage_daily/{docId}                            — server-only usage counters
//   /ai_coach_sessions/{sessionId}                     — coach session logs (owner-read)
//   /abuse_logs/{logId}                                — server-only abuse records
//   /notifications/{id}                                — global push-notification log (server-write)
//   /aiSuggestionLogs/{id}                             — server-only analytics
//
// Security model:
//   * Couple membership is the primary gate on all couple sub-collections.
//   * ai_usage_daily, abuse_logs, aiSuggestionLogs are server-admin only (deny all client).
//   * ai_coach_sessions are owner-readable (the authenticated user whose userId matches).
//   * Hard-delete of shared data is ONLY allowed when the couple doc status == "disconnected".

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() { return request.resource.data; }

    function coupleDoc(coupleId) {
      return get(/databases/$(database)/documents/couples/$(coupleId)).data;
    }

    function isCoupleMember(coupleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && ('userIds' in coupleDoc(coupleId))
        && request.auth.uid in coupleDoc(coupleId).userIds;
    }

    function isDisconnectedCouple(coupleId) {
      return isCoupleMember(coupleId)
        && coupleDoc(coupleId).get('status', 'active') == 'disconnected';
    }

    function isUnpaired(userData) {
      return !('coupleId' in userData)
        || userData.coupleId == null
        || userData.coupleId == '';
    }

    // ------------------------------------------------------------------
    // /users/{userId}
    // ------------------------------------------------------------------
    //
    // Read: self, or a verified couple-member doing a partner lookup.
    // This is tightened from the original "any signed-in user" to prevent
    // unauthenticated enumeration of all user profiles.

    match /users/{userId} {
      // Allow read if the requester is the owner, OR is already in the same
      // couple (partner lookup), OR the target is still unpaired (pairing flow).
      allow read: if isSelf(userId)
                  || (isSignedIn() && resource.data.get('coupleId', '') != ''
                      && isCoupleMember(resource.data.coupleId))
                  || (isSignedIn() && isUnpaired(resource.data));

      allow create: if isSelf(userId);

      allow update: if isSignedIn() && (
        isSelf(userId)

        // Pairing join — attaching as the partner of an unpaired user.
        || (
          isUnpaired(resource.data)
          && 'partnerId' in incoming()
          && incoming().partnerId == request.auth.uid
        )

        // Disconnect — the current partner clearing the pairing fields.
        || (
          'partnerId' in resource.data
          && resource.data.partnerId == request.auth.uid
        )
      );

      allow delete: if isSelf(userId);
    }

    // ------------------------------------------------------------------
    // /pairingCodes/{code}
    // ------------------------------------------------------------------

    match /pairingCodes/{code} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && incoming().creatorId == request.auth.uid;

      allow update: if isSignedIn()
                    && resource.data.creatorId == request.auth.uid
                    && incoming().creatorId == request.auth.uid;

      allow delete: if isSignedIn();
    }

    // ------------------------------------------------------------------
    // /couples/{coupleId}
    // ------------------------------------------------------------------

    match /couples/{coupleId} {

      allow get, list: if isSignedIn()
                       && resource != null
                       && 'userIds' in resource.data
                       && request.auth.uid in resource.data.userIds;

      allow create: if isSignedIn()
                    && incoming().userIds is list
                    && incoming().userIds.size() == 2
                    && request.auth.uid in incoming().userIds;

      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.userIds
                    && (
                      !('userIds' in incoming())
                      || (
                        incoming().userIds is list
                        && incoming().userIds.hasAll(resource.data.userIds)
                      )
                    );

      allow delete: if isSignedIn()
                    && request.auth.uid in resource.data.userIds
                    && resource.data.get('status', 'active') == 'disconnected';

      // ---- Shared mood feed ----
      match /moods/{moodId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && incoming().userId == request.auth.uid;
        allow update: if isCoupleMember(coupleId)
                      && resource.data.userId == request.auth.uid;
        allow delete: if isCoupleMember(coupleId) && (
          resource.data.userId == request.auth.uid
          || isDisconnectedCouple(coupleId)
        );

        match /reactions/{reactionId} {
          allow read: if isCoupleMember(coupleId);
          allow create: if isCoupleMember(coupleId)
                        && incoming().userId == request.auth.uid;
          allow update: if isCoupleMember(coupleId)
                        && resource.data.userId == request.auth.uid;
          allow delete: if isCoupleMember(coupleId) && (
            resource.data.userId == request.auth.uid
            || isDisconnectedCouple(coupleId)
          );
        }
      }

      // ---- Daily sync score rollups ----
      match /syncScores/{date} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Chat messages ----
      match /messages/{messageId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('senderId' in incoming())
                        || incoming().senderId == null
                        || incoming().senderId == request.auth.uid
                      );
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Chat quizzes ----
      match /quizzes/{quizId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Aggregated couple insight profile ----
      match /coupleProfile/{docId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Anniversary countdowns ----
      match /anniversaries/{anniversaryId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('createdBy' in incoming())
                        || incoming().createdBy == request.auth.uid
                      );
        allow update: if isCoupleMember(coupleId);
        allow delete: if isCoupleMember(coupleId);
      }

      // ---- Time Tree memories (past moments + capsules) ----
      match /memories/{memoryId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('createdBy' in incoming())
                        || incoming().createdBy == request.auth.uid
                      );
        allow update: if isCoupleMember(coupleId);
        allow delete: if isCoupleMember(coupleId);
      }

      // ---- Time Tree metadata (relationship anchor + future tree config) ----
      match /timeTreeMeta/{docId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isCoupleMember(coupleId);
      }

      // ---- Presence / ping firehose ----
      match /pings/{pingId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('fromUserId' in incoming())
                        || incoming().fromUserId == request.auth.uid
                      );
        allow update: if false;
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- In-app notifications ----
      match /notifications/{notifId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isCoupleMember(coupleId);
      }
    }

    // ------------------------------------------------------------------
    // /ai_usage_daily/{docId}
    // ------------------------------------------------------------------
    // Written and read exclusively by Cloud Functions (Admin SDK).
    // Clients cannot read, write, or infer their own quota state from here —
    // the 429 response from the function is the only signal they get.

    match /ai_usage_daily/{docId} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------
    // /ai_coach_sessions/{sessionId}
    // ------------------------------------------------------------------
    // Clients may read their own session logs (for history / stats) but
    // may never write — the server is the only writer.

    match /ai_coach_sessions/{sessionId} {
      allow read:  if isSignedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // ------------------------------------------------------------------
    // /abuse_logs/{logId}
    // ------------------------------------------------------------------
    // Strictly server-only. Never exposed to clients.

    match /abuse_logs/{logId} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------
    // /aiSuggestionLogs/{logId}
    // ------------------------------------------------------------------
    // Analytics — server-only.

    match /aiSuggestionLogs/{logId} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------
    // /notifications/{id}  (global push-notification log)
    // ------------------------------------------------------------------
    // Written by Cloud Functions via Admin SDK.
    // Not exposed to clients (couple-scoped in-app notifications live
    // under couples/{id}/notifications instead).

    match /notifications/{notifId} {
      allow read, write: if false;
    }

    // ------------------------------------------------------------------
    // Catch-all: deny everything not explicitly allowed above.
    // ------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
