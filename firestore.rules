rules_version = '2';

// Firestore security rules for Coupley.
//
// Data model:
//   /users/{uid}                                       — user profile + tokens
//   /pairingCodes/{code}                               — ephemeral invite codes
//   /couples/{coupleId}                                — userIds: [uidA, uidB]
//     /moods/{moodId}                                  — author: userId
//       /reactions/{reactionId}                        — author: userId
//     /syncScores/{date}                               — daily rollup
//     /messages/{msgId}                                — chat messages
//     /quizzes/{quizId}                                — chat quizzes
//     /coupleProfile/{docId}                           — aggregated insights
//     /anniversaries/{id}                              — anniversary events
//     /pings/{pingId}                                  — presence heartbeats
//     /notifications/{id}                              — in-app notifications
//
// Security model:
//   * Couple membership is the primary gate: `isCoupleMember(coupleId)`
//     checks userIds on the parent couple doc.
//   * Pairing (cross-user write) and soft-disconnect (partner-scoped write)
//     are explicit carve-outs on /users/{uid}.
//   * Hard-delete of shared data is ONLY allowed when the couple doc's
//     status is "disconnected" — prevents accidental wipe of an active pairing.

service cloud.firestore {
  match /databases/{database}/documents {

    // ------------------------------------------------------------------
    // Helpers
    // ------------------------------------------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function incoming() { return request.resource.data; }

    function coupleDoc(coupleId) {
      return get(/databases/$(database)/documents/couples/$(coupleId)).data;
    }

    function isCoupleMember(coupleId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/couples/$(coupleId))
        && ('userIds' in coupleDoc(coupleId))
        && request.auth.uid in coupleDoc(coupleId).userIds;
    }

    // True iff the couple has already been soft-disconnected. Used to gate
    // hard-delete: we never allow destructive writes on an active pairing.
    function isDisconnectedCouple(coupleId) {
      return isCoupleMember(coupleId)
        && coupleDoc(coupleId).get('status', 'active') == 'disconnected';
    }

    // A user is "unpaired" if their doc carries no live coupleId. We treat
    // missing / null / "" as unpaired so the pairing join write is safe.
    function isUnpaired(userData) {
      return !('coupleId' in userData)
        || userData.coupleId == null
        || userData.coupleId == '';
    }

    // ------------------------------------------------------------------
    // /users/{userId}
    // ------------------------------------------------------------------
    //
    // Reads: any signed-in user (pairing preview, partner lookup, presence).
    // Create: owner only.
    // Update: owner, OR joiner attaching themselves to an unpaired creator
    //   during pairing, OR the current partner flipping disconnect fields.
    // Delete: owner only.

    match /users/{userId} {
      allow read:   if isSignedIn();
      allow create: if isSelf(userId);

      allow update: if isSignedIn() && (
        // 1. Owner updates their own doc.
        isSelf(userId)

        // 2. Pairing join — the caller is attaching as the partner of
        //    a currently-unpaired user. We require:
        //      - the target is unpaired (no live coupleId)
        //      - incoming.partnerId == auth.uid (you name yourself as partner)
        //    The matching couple create happens atomically in the same batch.
        || (
          isUnpaired(resource.data)
          && 'partnerId' in incoming()
          && incoming().partnerId == request.auth.uid
        )

        // 3. Disconnect — the caller is the current partner of the target.
        //    Permits clearing coupleId/partnerId and setting lastCoupleId /
        //    lastPartnerId / pendingDisconnectNotice / lastPartnerName.
        || (
          'partnerId' in resource.data
          && resource.data.partnerId == request.auth.uid
        )
      );

      allow delete: if isSelf(userId);
    }

    // ------------------------------------------------------------------
    // /pairingCodes/{code}
    // ------------------------------------------------------------------

    match /pairingCodes/{code} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && incoming().creatorId == request.auth.uid;

      allow update: if isSignedIn()
                    && resource.data.creatorId == request.auth.uid
                    && incoming().creatorId == request.auth.uid;

      // Deletion happens either when the creator revokes or when the
      // joining user consumes the code in the pairing batch. Both are
      // authenticated flows; codes are single-use 6-char secrets.
      allow delete: if isSignedIn();
    }

    // ------------------------------------------------------------------
    // /couples/{coupleId}
    // ------------------------------------------------------------------

    match /couples/{coupleId} {

      allow get, list: if isSignedIn()
                       && resource != null
                       && 'userIds' in resource.data
                       && request.auth.uid in resource.data.userIds;

      // Create: any signed-in user may create the doc during pairing,
      // but it must name exactly two participants including themself.
      allow create: if isSignedIn()
                    && incoming().userIds is list
                    && incoming().userIds.size() == 2
                    && request.auth.uid in incoming().userIds;

      // Update: requester must already be a member, and the participant
      // list (if present) must still contain both original members.
      allow update: if isSignedIn()
                    && request.auth.uid in resource.data.userIds
                    && (
                      !('userIds' in incoming())
                      || (
                        incoming().userIds is list
                        && incoming().userIds.hasAll(resource.data.userIds)
                      )
                    );

      // Delete: only after soft-disconnect, and only by a member.
      // The client calls this as the final step of deleteSharedData().
      allow delete: if isSignedIn()
                    && request.auth.uid in resource.data.userIds
                    && resource.data.get('status', 'active') == 'disconnected';

      // ----------------------------------------------------------------
      // Sub-collections
      // ----------------------------------------------------------------

      // ---- Shared mood feed ----
      match /moods/{moodId} {
        allow read: if isCoupleMember(coupleId);

        allow create: if isCoupleMember(coupleId)
                      && incoming().userId == request.auth.uid;
        allow update: if isCoupleMember(coupleId)
                      && resource.data.userId == request.auth.uid;
        // Author can delete their own; either member can delete once the
        // couple is disconnected (hard-cleanup sweep).
        allow delete: if isCoupleMember(coupleId) && (
          resource.data.userId == request.auth.uid
          || isDisconnectedCouple(coupleId)
        );

        // ---- Reactions on a mood entry ----
        match /reactions/{reactionId} {
          allow read: if isCoupleMember(coupleId);
          allow create: if isCoupleMember(coupleId)
                        && incoming().userId == request.auth.uid;
          allow update: if isCoupleMember(coupleId)
                        && resource.data.userId == request.auth.uid;
          allow delete: if isCoupleMember(coupleId) && (
            resource.data.userId == request.auth.uid
            || isDisconnectedCouple(coupleId)
          );
        }
      }

      // ---- Daily sync score rollups ----
      match /syncScores/{date} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Chat messages ----
      match /messages/{messageId} {
        allow read: if isCoupleMember(coupleId);

        // User-authored messages must carry the sender's uid. System /
        // quiz / result cards are authored with senderId == null.
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('senderId' in incoming())
                        || incoming().senderId == null
                        || incoming().senderId == request.auth.uid
                      );

        // Either partner may mark a message read (readBy updates).
        allow update: if isCoupleMember(coupleId);

        // Hard-cleanup only.
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Chat quizzes (path: quizzes) ----
      match /quizzes/{quizId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Aggregated couple insight profile ----
      match /coupleProfile/{docId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- Anniversary countdowns ----
      match /anniversaries/{anniversaryId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('createdBy' in incoming())
                        || incoming().createdBy == request.auth.uid
                      );
        allow update: if isCoupleMember(coupleId);
        allow delete: if isCoupleMember(coupleId);
      }

      // ---- Presence / ping firehose ----
      match /pings/{pingId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
                      && (
                        !('fromUserId' in incoming())
                        || incoming().fromUserId == request.auth.uid
                      );
        allow update: if false;
        allow delete: if isDisconnectedCouple(coupleId);
      }

      // ---- In-app notifications ----
      match /notifications/{notifId} {
        allow read:   if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId);
        allow update: if isCoupleMember(coupleId);
        allow delete: if isCoupleMember(coupleId);
      }
    }

    // ------------------------------------------------------------------
    // Catch-all: deny everything not explicitly allowed above.
    // ------------------------------------------------------------------

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
